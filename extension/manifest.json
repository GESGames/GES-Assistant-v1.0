{
  "manifest_version": 3,
  "name": "GES Assistant V1.0",
  "version": "1.0",
  "description": "Asistente de IA Retro para automatizar tareas.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://*.google.com/*",
    "https://*.linkedin.com/*",
    "https://*.notion.so/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}